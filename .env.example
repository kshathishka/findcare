# Spring profile and runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# JWT configuration
# Long and random secret used to sign JWT tokens.
JWT_SECRET=replace-with-long-random-secret
# Token expiration in milliseconds.
JWT_EXPIRATION_MS=86400000

# CORS configuration
# Comma-separated allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Login rate limiting
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# MySQL configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=findcare
DB_USERNAME=findcare
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password
DB_USE_SSL=false

# Optional Hikari tuning
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_MAX_LIFETIME_MS=1800000

# Docker Hub for CI image push
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_BACKEND_REPO=findcare-backend
DOCKERHUB_FRONTEND_REPO=findcare-frontend
